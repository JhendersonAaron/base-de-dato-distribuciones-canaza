select
    p.id_producto,
    p.cod_interno,
    trim(p.descripcion) as descripcion,
    p.cod_unidad_med,
    p.costo_compra,
    p.precio_venta,
    p.precio_venta_igv,
    p.stock_actual,
    c.id_categoria,
    c.cod_categoria,
    c.desc_categoria
from productos p
left join categorias c
    on p.id_categoria = c.id_categoria
  );
